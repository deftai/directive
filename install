#!/usr/bin/env sh
# Deft installer — Unix wrapper
# Delegates to install.py after verifying python3 is available.
# Usage: deft/install [options]

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 not found. Install Python 3.13+ from https://python.org" >&2
    exit 1
fi

exec python3 "$SCRIPT_DIR/install.py" "$@"
